generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    BUYER
    SUPPLIER
}

enum AuctionStatus {
    DRAFT
    ACTIVE
    CLOSED
    FORCE_CLOSED
}

enum ExtensionTriggerType {
    BID_RECEIVED
    ANY_RANK_CHANGE
    L1_CHANGE_ONLY
}

enum ActivityType {
    BID_SUBMITTED
    AUCTION_EXTENDED
    AUCTION_OPENED
    AUCTION_CLOSED
    AUCTION_FORCE_CLOSED
    RANK_CHANGED
}

model User {
    id           String @id @default(uuid())
    email        String @unique
    passwordHash String
    name         String
    role         Role
    rfqs RFQ[] @relation("BuyerRFQs")
    bids Bid[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    @@index([email])
    @@index([role])
}

model RFQ {
    id          String @id @default(uuid())
    referenceId String @unique
    name    String
    buyerId String
    buyer   User   @relation("BuyerRFQs", fields: [buyerId], references: [id])
    bidStartTime         DateTime
    bidCloseTime         DateTime
    originalBidCloseTime DateTime
    forcedCloseTime      DateTime
    pickupDate DateTime
    status AuctionStatus @default(DRAFT)
    auctionConfig AuctionConfig?
    bids          Bid[]
    extensions    AuctionExtension[]
    activityLogs  ActivityLog[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    @@index([status])
    @@index([buyerId])
    @@index([bidCloseTime])
}

model AuctionConfig {
    id    String @id @default(uuid())
    rfqId String @unique
    rfq   RFQ    @relation(fields: [rfqId], references: [id])
    triggerWindowMins Int
    extensionDurationMins Int
    triggerType ExtensionTriggerType
    createdAt DateTime @default(now())
}

model Bid {
    id         String @id @default(uuid())
    rfqId      String
    rfq        RFQ    @relation(fields: [rfqId], references: [id])
    supplierId String
    supplier   User   @relation(fields: [supplierId], references: [id])
    carrierName        String
    freightCharges     Decimal  @db.Decimal(12, 2)
    originCharges      Decimal  @db.Decimal(12, 2)
    destinationCharges Decimal  @db.Decimal(12, 2)
    transitTimeDays    Int
    quoteValidityDate  DateTime
    totalAmount Decimal @db.Decimal(12, 2)
    rankAtSubmission Int
    receivedAt DateTime @default(now())
    triggeredExtension AuctionExtension?
    createdAt DateTime @default(now())
    @@index([rfqId, supplierId])
    @@index([rfqId, totalAmount, receivedAt])
    @@index([rfqId, receivedAt])
}

model AuctionExtension {
    id    String @id @default(uuid())
    rfqId String
    rfq   RFQ    @relation(fields: [rfqId], references: [id])
    triggeringBidId String @unique
    triggeringBid   Bid    @relation(fields: [triggeringBidId], references: [id])
    triggerType ExtensionTriggerType
    previousCloseTime DateTime
    newCloseTime      DateTime
    createdAt DateTime @default(now())
    @@index([rfqId])
}

model ActivityLog {
    id    String @id @default(uuid())
    rfqId String
    rfq   RFQ    @relation(fields: [rfqId], references: [id])
    activityType ActivityType
    description String
    bidId String?
    extensionId String?
    occurredAt DateTime @default(now())
    @@index([rfqId, occurredAt])
}