generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model DummyItem {
    id        String   @id @default(cuid())
    name      String
    notes     String?
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
